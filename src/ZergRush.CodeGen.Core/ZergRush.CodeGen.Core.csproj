<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Description>Runtime attributes, contracts, serialization helpers, and object lifecycle utilities shared by the ZergRush code-generation tools.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>
  <ItemGroup Condition="'$(ZergRushReactiveProjectPath)' != ''">
    <ProjectReference Include="$(ZergRushReactiveProjectPath)" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\..\Runtime\**\*.cs" />
  </ItemGroup>
</Project>
